{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Office",
  "version": "0.1.0",
  "identifier": "app.hermesoffice.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @hermes-office/web",
    "devUrl": "http://localhost:4173",
    "beforeBuildCommand": "npm run build --workspace @hermes-office/web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Office",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
